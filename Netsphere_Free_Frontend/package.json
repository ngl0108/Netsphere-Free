{
  "name": "Netsphere_Free_Frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "prebuild": "node scripts/prebuild-quality-gate.mjs",
    "build": "vite build",
    "build:guarded": "python ../Netsphere_Free_Backend/tools/run_local_quality_gate.py --skip-e2e --skip-build",
    "build:release": "python ../Netsphere_Free_Backend/tools/run_local_quality_gate.py --skip-build",
    "lint": "eslint .",
    "contract:api": "node scripts/check-api-contract.mjs",
    "i18n:audit": "node scripts/check-i18n-coverage.mjs",
    "i18n:audit:strict": "node scripts/check-i18n-coverage.mjs --strict",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "e2e:doctor": "node scripts/e2e-doctor.mjs",
    "preview": "vite preview",
    "e2e": "node ./node_modules/@playwright/test/cli.js test",
    "e2e:free": "node ./node_modules/@playwright/test/cli.js test tests/e2e/discovery-flow.spec.js tests/e2e/discovery-plug-and-scan-autoprovision.spec.js tests/e2e/approval-topology-reflection.spec.js tests/e2e/topology-candidate-queue.spec.js tests/e2e/topology-path-trace-enhanced.spec.js tests/e2e/diagnosis-enhanced.spec.js tests/e2e/free-intake-contribution.spec.js tests/e2e/free-route-guard.spec.js",
    "e2e:ops": "node ./node_modules/@playwright/test/cli.js test tests/e2e/login-success.spec.js tests/e2e/discovery-plug-and-scan-autoprovision.spec.js tests/e2e/approval-topology-reflection.spec.js tests/e2e/cloud-accounts-access.spec.js tests/e2e/dashboard-operational-kpi.spec.js tests/e2e/observability-toggle.spec.js tests/e2e/session-polling-stability.spec.js tests/e2e/settings-webhook-resilience.spec.js tests/e2e/settings-webhook-connector.spec.js tests/e2e/synthetic-ops-resilience.spec.js tests/e2e/topology-bgp-visibility.spec.js tests/e2e/topology-overlay-visibility.spec.js tests/e2e/topology-hybrid-visibility.spec.js tests/e2e/topology-realtime-refresh.spec.js tests/e2e/topology-path-trace-enhanced.spec.js tests/e2e/topology-candidate-queue.spec.js tests/e2e/config-template-deploy-guard.spec.js tests/e2e/compliance-report-automation.spec.js tests/e2e/notifications-automation.spec.js tests/e2e/diagnosis-enhanced.spec.js",
    "capture:website-evidence": "node ./node_modules/@playwright/test/cli.js test tests/e2e/website-evidence-capture.spec.js",
    "e2e:ops:docker": "node scripts/run-e2e-ops-docker.mjs",
    "e2e:ui": "node ./node_modules/@playwright/test/cli.js test --ui",
    "e2e:install": "node ./node_modules/@playwright/test/cli.js install chromium"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "elkjs": "^0.8.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.11.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4"
  }
}
